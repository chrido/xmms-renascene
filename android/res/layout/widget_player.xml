<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_player_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Open XMMS Renascene"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="116">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="88" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="18"
            android:orientation="horizontal"
            android:weightSum="275">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="16" />

            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="23"
                android:background="@android:color/transparent"
                android:contentDescription="Previous" />

            <ImageButton
                android:id="@+id/widget_play"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="23"
                android:background="@android:color/transparent"
                android:contentDescription="Play" />

            <ImageButton
                android:id="@+id/widget_pause"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="23"
                android:background="@android:color/transparent"
                android:contentDescription="Pause" />

            <ImageButton
                android:id="@+id/widget_stop"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="23"
                android:background="@android:color/transparent"
                android:contentDescription="Stop" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="22"
                android:background="@android:color/transparent"
                android:contentDescription="Next" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="145" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10" />

    </LinearLayout>

</FrameLayout>
